# MySQL 连接配置
MYSQL_HOST=localhost
MYSQL_PORT=23306
MYSQL_DATABASE=ocqa
MYSQL_USER=root
MYSQL_PASSWORD=your-password

# JWT 鉴权。生产环境必须覆盖默认开发密钥，密钥长度至少 32 字符。
CKQA_JWT_SECRET=please-change-this-local-jwt-secret-at-least-32-chars
CKQA_JWT_ISSUER=ckqa-back
CKQA_JWT_TTL=PT8H

# 课程封面上传。封面对象会写入 MinIO 的 COURSE_COVER_BUCKET/COURSE_COVER_OBJECT_PREFIX。
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=12345678
MINIO_SECURE=false
COURSE_COVER_BUCKET=course-artifacts
COURSE_COVER_OBJECT_PREFIX=course-covers
COURSE_COVER_MAX_FILE_SIZE_BYTES=2097152

# 用户头像和课程资料对象存储。默认与课程封面共用 course-artifacts bucket。
# 课程资料 v1 仅支持 PDF，单文件默认上限 200MB。
USER_AVATAR_BUCKET=course-artifacts
USER_AVATAR_OBJECT_PREFIX=user-avatars
USER_AVATAR_MAX_FILE_SIZE_BYTES=2097152
COURSE_MATERIAL_BUCKET=course-artifacts
COURSE_MATERIAL_OBJECT_PREFIX=course-materials
COURSE_MATERIAL_MAX_FILE_SIZE_BYTES=209715200
CKQA_MULTIPART_MAX_FILE_SIZE=200MB
CKQA_MULTIPART_MAX_REQUEST_SIZE=200MB

# PDF 解析链路
# 留空时后端会自动优先寻找 ~/miniconda3/envs/courseKg/bin/python；
# 如需强制指定解释器，再填写真实绝对路径。
PDF_INGEST_PYTHON=
PDF_INGEST_ROOT=/home/sunlight/Projects/ckqa/pdf_ingest

# GraphRAG 索引与问答链路
# 留空时后端会自动优先寻找 ~/miniconda3/envs/graphrag-oneapi/bin/python。
GRAPHRAG_PYTHON=
GRAPHRAG_ROOT=/home/sunlight/Projects/ckqa/graphrag_pipeline
GRAPHRAG_API_HOST=127.0.0.1
GRAPHRAG_API_PORT=8012
GRAPHRAG_API_BASE_URL=http://127.0.0.1:8012
GRAPHRAG_API_MANAGED_ENABLED=false
GRAPHRAG_CONDA_ENV=graphrag-oneapi
GRAPHRAG_BUILD_RUNS_ROOT=/home/sunlight/Projects/ckqa/graphrag_pipeline/runtime/kb-build-runs
GRAPHRAG_ALLOW_CONCURRENT_KB_BUILDS=true
GRAPHRAG_AUTO_ACTIVATION_POLICY=latest-build-only
GRAPHRAG_KEEP_SUCCESS_BUILD_RUNS=3
GRAPHRAG_KEEP_FAILED_BUILD_RUNS=3
GRAPHRAG_BUILD_RUN_AUTO_CLEANUP_ENABLED=false

# 一期同步编排超时配置（秒）
PARSE_TIMEOUT_SECONDS=900
EXPORT_TIMEOUT_SECONDS=300
FETCH_TIMEOUT_SECONDS=300
INDEX_TIMEOUT_SECONDS=1800
QUERY_TIMEOUT_SECONDS=120
QUERY_TASK_POLLING_INTERVAL_SECONDS=10
QUERY_TASK_STALE_SECONDS=300

# 问答异步任务可按 mode 覆盖轮询建议与 stale 阈值。
# 基于 2026-04-23 主分支现有图谱单轮实测：
# local 约 110 秒，global 约 800 秒，drift 约 725 秒。
QUERY_TASK_POLLING_INTERVAL_SECONDS_LOCAL=10
QUERY_TASK_POLLING_INTERVAL_SECONDS_GLOBAL=30
QUERY_TASK_POLLING_INTERVAL_SECONDS_BASIC=10
QUERY_TASK_POLLING_INTERVAL_SECONDS_DRIFT=30
QUERY_TASK_STALE_SECONDS_LOCAL=300
QUERY_TASK_STALE_SECONDS_GLOBAL=1800
QUERY_TASK_STALE_SECONDS_BASIC=300
QUERY_TASK_STALE_SECONDS_DRIFT=1800
QUERY_TASK_TIMEOUT_MESSAGE_LOCAL=local 模式实测可能需要 2 分钟左右；任务心跳超过阈值未更新后会被标记为 stale。
QUERY_TASK_TIMEOUT_MESSAGE_GLOBAL=global 模式实测可能需要 10 到 20 分钟；建议前端低频轮询并展示长耗时提示。
QUERY_TASK_TIMEOUT_MESSAGE_BASIC=basic 模式沿用轻量查询策略；任务心跳超过阈值未更新后会被标记为 stale。
QUERY_TASK_TIMEOUT_MESSAGE_DRIFT=drift 模式实测可能需要 10 到 20 分钟；建议前端低频轮询并展示长耗时提示。

# 超过阈值仍为 running 的索引任务将被恢复为 failed
INDEX_STALE_SECONDS=2400


# Redis（限频与邮箱验证码缓存）；与 infra/.env 中的 REDIS_PASSWORD / CKQA_REDIS_PORT 保持一致
CKQA_REDIS_HOST=127.0.0.1
CKQA_REDIS_PORT=16379
REDIS_PASSWORD=

# 登录限频策略（默认 5 次/15 分钟，触发后锁 5 分钟）
CKQA_LOGIN_MAX_FAILURES=5
CKQA_LOGIN_FAILURE_WINDOW=PT15M
CKQA_LOGIN_LOCK_DURATION=PT5M

# 邮箱验证码登录策略（开发态可保持默认；mailer-type=log 验证码会打到后端日志）
CKQA_EMAIL_CODE_LENGTH=6
CKQA_EMAIL_CODE_TTL=PT5M
CKQA_EMAIL_CODE_COOLDOWN=PT60S
CKQA_EMAIL_CODE_DAILY_QUOTA=5
CKQA_EMAIL_MAILER_TYPE=log
CKQA_EMAIL_FROM_ADDRESS=noreply@ckqa.local
CKQA_EMAIL_FROM_NAME=智课问答
# 接入真实 SMTP 时把 mailer-type 改为 smtp 并填写以下 5 项
CKQA_EMAIL_SMTP_HOST=
CKQA_EMAIL_SMTP_PORT=465
CKQA_EMAIL_SMTP_USERNAME=
CKQA_EMAIL_SMTP_PASSWORD=
CKQA_EMAIL_SMTP_SSL=true

# Cloudflare Turnstile 人机验证（默认禁用；上线时配 site-key + secret-key）
CKQA_TURNSTILE_ENABLED=false
CKQA_TURNSTILE_SECRET_KEY=
