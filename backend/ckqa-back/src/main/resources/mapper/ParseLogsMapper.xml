<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.ysu.ckqaback.mapper.ParseLogsMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="org.ysu.ckqaback.entity.ParseLogs">
        <id column="id" property="id" />
        <result column="pdf_file_id" property="pdfFileId" />
        <result column="log_level" property="logLevel" />
        <result column="log_message" property="logMessage" />
        <result column="created_at" property="createdAt" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, pdf_file_id, log_level, log_message, created_at
    </sql>

</mapper>
