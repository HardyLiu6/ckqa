<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.ysu.ckqaback.mapper.ParseResultsMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="org.ysu.ckqaback.entity.ParseResults">
        <id column="id" property="id" />
        <result column="pdf_file_id" property="pdfFileId" />
        <result column="course_id" property="courseId" />
        <result column="result_type" property="resultType" />
        <result column="file_name" property="fileName" />
        <result column="minio_bucket" property="minioBucket" />
        <result column="minio_object_key" property="minioObjectKey" />
        <result column="file_size" property="fileSize" />
        <result column="created_at" property="createdAt" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, pdf_file_id, course_id, result_type, file_name, minio_bucket, minio_object_key, file_size, created_at
    </sql>

</mapper>
