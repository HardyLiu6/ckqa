<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.ysu.ckqaback.mapper.QaMessagesMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="org.ysu.ckqaback.entity.QaMessages">
        <id column="id" property="id" />
        <result column="session_id" property="sessionId" />
        <result column="role" property="role" />
        <result column="sequence_no" property="sequenceNo" />
        <result column="content" property="content" />
        <result column="content_text" property="contentText" />
        <result column="token_count" property="tokenCount" />
        <result column="copied_from_message_id" property="copiedFromMessageId" />
        <result column="created_at" property="createdAt" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, session_id, role, sequence_no, content, content_text, token_count, copied_from_message_id, created_at
    </sql>

</mapper>
