<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.ysu.ckqaback.mapper.QaRetrievalHitsMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="org.ysu.ckqaback.entity.QaRetrievalHits">
        <id column="id" property="id" />
        <result column="retrieval_log_id" property="retrievalLogId" />
        <result column="document_key" property="documentKey" />
        <result column="chunk_id" property="chunkId" />
        <result column="source_ref" property="sourceRef" />
        <result column="source_file" property="sourceFile" />
        <result column="heading_path" property="headingPath" />
        <result column="page_start" property="pageStart" />
        <result column="page_end" property="pageEnd" />
        <result column="snippet" property="snippet" />
        <result column="rank_position" property="rankPosition" />
        <result column="score" property="score" />
        <result column="created_at" property="createdAt" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, retrieval_log_id, document_key, chunk_id, source_ref, source_file, heading_path,
        page_start, page_end, snippet, rank_position, score, created_at
    </sql>

</mapper>
