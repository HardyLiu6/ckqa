<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.ysu.ckqaback.mapper.QaSessionsMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="org.ysu.ckqaback.entity.QaSessions">
        <id column="id" property="id" />
        <result column="session_code" property="sessionCode" />
        <result column="user_id" property="userId" />
        <result column="course_id" property="courseId" />
        <result column="course_membership_id" property="courseMembershipId" />
        <result column="knowledge_base_id" property="knowledgeBaseId" />
        <result column="index_run_id" property="indexRunId" />
        <result column="index_locked_at" property="indexLockedAt" />
        <result column="session_type" property="sessionType" />
        <result column="parent_session_id" property="parentSessionId" />
        <result column="forked_from_message_id" property="forkedFromMessageId" />
        <result column="forked_from_sequence_no" property="forkedFromSequenceNo" />
        <result column="fork_reason" property="forkReason" />
        <result column="transcript_version" property="transcriptVersion" />
        <result column="title" property="title" />
        <result column="status" property="status" />
        <result column="last_message_at" property="lastMessageAt" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, session_code, user_id, course_id, course_membership_id, knowledge_base_id, index_run_id,
        index_locked_at, session_type, parent_session_id, forked_from_message_id, forked_from_sequence_no,
        fork_reason, transcript_version, title, status, last_message_at, created_at, updated_at
    </sql>

    <!-- 「问答记录」统计卡片：按筛选条件在库层聚合，反映全部历史的真实口径，不受分页截断影响 -->
    <select id="selectFormalSessionStats" resultType="org.ysu.ckqaback.qa.dto.QaSessionStatsResponse">
        SELECT
          COUNT(DISTINCT s.id) AS totalSessions,
          COUNT(m.id) AS totalMessages,
          COUNT(DISTINCT s.course_id) AS courseCount
        FROM qa_sessions s
        LEFT JOIN qa_messages m ON m.session_id = s.id
        WHERE s.user_id = #{userId}
          AND s.session_type = 'formal'
          <if test="status != null and status != ''">
            AND s.status = #{status}
          </if>
          <if test="courseId != null and courseId != ''">
            AND s.course_id = #{courseId}
          </if>
          <if test="knowledgeBaseId != null">
            AND s.knowledge_base_id = #{knowledgeBaseId}
          </if>
    </select>

</mapper>
