{
  "schema_version": "v1",
  "domain": "course_qa",
  "scenario": "面向课程的混合式问答系统设计与实现",
  "design_principles": [
    "只抽取服务于课程问答、知识建图和教学评测的课程领域实体",
    "默认以课程内边界为主，不在当前版本中跨课程自动合并同名实体",
    "优先保留教学结构、知识对象、学习活动和工具平台四类实体"
  ],
  "entity_type_order": [
    "Course",
    "Chapter",
    "Section",
    "KnowledgePoint",
    "Concept",
    "Term",
    "FormulaOrDefinition",
    "AlgorithmOrMethod",
    "Experiment",
    "Assignment",
    "ToolOrPlatform"
  ],
  "entity_types": {
