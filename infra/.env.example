# 复制为 infra/.env 后再执行 docker compose up -d。
# 复用旧 MySQL 数据时，MYSQL_ROOT_PASSWORD 必须填写当前容器真实 root 密码；
# 不要把 infra/.env 提交到 Git。

TZ=Asia/Shanghai

MYSQL_ROOT_PASSWORD=change_me_to_current_mysql_root_password
MYSQL_DATABASE=ocqa
CKQA_MYSQL_PORT=23306
CKQA_MYSQL_DATA_DIR=/home/sunlight/mysql/data

MINIO_ROOT_USER=change_me_to_current_minio_user
MINIO_ROOT_PASSWORD=change_me_to_current_minio_password
CKQA_MINIO_API_PORT=9000
CKQA_MINIO_CONSOLE_PORT=9001
CKQA_MINIO_DATA_DIR=/home/sunlight/minio/data

CKQA_ONE_API_PORT=3301

NEO4J_AUTH=neo4j/neo4j_password_change_me
CKQA_NEO4J_HTTP_PORT=17474
CKQA_NEO4J_BOLT_PORT=17687
CKQA_NEO4J_HEAP_MAX=2G
CKQA_NEO4J_PAGECACHE=1G

# Redis（限频计数器、邮箱验证码缓存）
# REDIS_PASSWORD 留空时匿名访问，仅本机开发推荐；上线请务必填写并配套调整后端连接配置。
CKQA_REDIS_PORT=16379
REDIS_PASSWORD=
